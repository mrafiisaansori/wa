# Port HTTP internal untuk API wagateway (jangan diexpose langsung ke publik, panggil dari pos-backend lewat localhost)
PORT=3900

# Wajib diisi sebelum production - kunci ini yang dicek di header X-API-Key tiap request /send
API_KEY=ganti-dengan-secret-acak-yang-panjang

# Nomor WA yang mau dipakai buat gateway, format 628xxxxxxxxxx (kode negara, tanpa + / spasi / strip)
# Cuma dipakai sekali waktu pairing pertama - setelah tertaut boleh dikosongkan/dihapus dari .env
PAIR_NUMBER=628xxxxxxxxxx

# Jeda antar pesan dalam milidetik - jaga tetap wajar (jangan kirim beruntun cepat), default 3 detik
SEND_DELAY_MS=3000

# Login buat buka Swagger UI (/docs) - Basic Auth, bukan API_KEY. Kalau DOCS_PASS
# kosong, /docs otomatis dinonaktifkan (fail closed, bukan malah kebuka bebas).
DOCS_USER=admin
DOCS_PASS=ganti-dengan-password-kuat

# silent | info | debug - biarkan silent di production, ganti ke debug cuma waktu troubleshooting
LOG_LEVEL=silent
