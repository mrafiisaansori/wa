# Port HTTP internal untuk API wagateway (jangan diexpose langsung ke publik, panggil dari project pemanggil lewat localhost)
PORT=3900

# Rentang jeda antar pesan dalam milidetik, DIACAK di antara keduanya tiap kirim
# (bukan jeda tetap) - jaga tetap wajar biar tidak kelihatan pola "blasting", dipakai
# baik oleh /send maupun /broadcast. Default 2.5-6 detik.
SEND_DELAY_MIN_MS=2500
SEND_DELAY_MAX_MS=6000

# Batas jumlah pesan broadcast per tenant per hari (kalkulasi mundur dari
# riwayat_pesan). Batch broadcast yang melebihi sisa kuota ditolak seluruhnya.
BROADCAST_DAILY_LIMIT=200

# Secret buat menandatangani cookie sesi login dashboard - isi string acak
# panjang (mis. hasil `openssl rand -hex 32`). Kalau kosong, server tetap jalan
# pakai secret acak sementara, tapi semua sesi login putus tiap restart.
SESSION_SECRET=

# Login admin buat buka /docs/admin dan endpoint /admin/* (provisioning tenant).
# Kalau DOCS_PASS kosong, semua endpoint admin otomatis dinonaktifkan (fail closed).
DOCS_USER=admin
DOCS_PASS=ganti-dengan-password-kuat

# Login TERPISAH cuma buat buka halaman /docs/app TANPA login tenant (opsional -
# kalau sudah login dashboard sebagai tenant, sesi itu otomatis cukup buat buka
# /docs/app juga). Eksekusi /send, /broadcast, /device/*, /history tetap minta
# login aplikasi lagi lewat tombol Authorize di Swagger.
APP_DOCS_USER=app
APP_DOCS_PASS=ganti-dengan-password-kuat-lain

# silent | info | debug - biarkan silent di production, ganti ke debug cuma waktu troubleshooting
LOG_LEVEL=silent

# Koneksi database (dibuat dari wagateway.sql)
DB_HOST=localhost
DB_USER=root
DB_PASS=ganti-dengan-password-mysql
DB_NAME=wagateway
