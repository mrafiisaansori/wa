# Port HTTP internal untuk API wagateway (jangan diexpose langsung ke publik, panggil dari project pemanggil lewat localhost)
PORT=3900

# Nomor WA yang mau dipakai buat gateway, format 628xxxxxxxxxx (kode negara, tanpa + / spasi / strip)
# Cuma dipakai sekali waktu pairing pertama - setelah tertaut boleh dikosongkan/dihapus dari .env
PAIR_NUMBER=628xxxxxxxxxx

# Jeda antar pesan dalam milidetik - jaga tetap wajar (jangan kirim beruntun cepat), default 3 detik
SEND_DELAY_MS=3000

# Login admin buat buka Swagger (/docs/admin, /docs/app) dan endpoint /admin/*.
# Kalau DOCS_PASS kosong, semua endpoint admin otomatis dinonaktifkan (fail closed).
DOCS_USER=admin
DOCS_PASS=ganti-dengan-password-kuat

# silent | info | debug - biarkan silent di production, ganti ke debug cuma waktu troubleshooting
LOG_LEVEL=silent

# Koneksi database (dibuat dari wagateway.sql)
DB_HOST=localhost
DB_USER=root
DB_PASS=ganti-dengan-password-mysql
DB_NAME=wagateway
